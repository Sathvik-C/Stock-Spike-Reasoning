# Copy this file to backend/.env and fill in your values
# Never commit the actual .env file to git

# Required: Get a free key at https://newsdata.io/register
NEWSDATA_API_KEY=your_newsdata_api_key_here

# Required for production: Comma-separated list of your frontend URLs
# Example: https://your-app.onrender.com,http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Optional: Use PostgreSQL instead of SQLite
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# Optional: Set to False in production
DEBUG=False
